# Copy this file to .env.local and fill in your keys.
OPENAI_API_KEY=
YOUTUBE_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional — enables Supabase persistence (trend comparison, history, search).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional — password-protect the whole site (great for sharing a deployment).
# Leave SITE_PASSWORD blank to disable the gate. Username defaults to "manager".
SITE_USERNAME=manager
SITE_PASSWORD=
